<svg width="512" height="512" viewBox="0 0 512 512" fill="none" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="512" height="512" rx="64" fill="#2563eb"/>
  
  <!-- Blueprint grid pattern -->
  <defs>
    <pattern id="grid-large" width="64" height="64" patternUnits="userSpaceOnUse">
      <line x1="0" y1="32" x2="64" y2="32" stroke="#ffffff" stroke-width="1" opacity="0.15"/>
      <line x1="32" y1="0" x2="32" y2="64" stroke="#ffffff" stroke-width="1" opacity="0.15"/>
    </pattern>
  </defs>
  <rect width="512" height="512" fill="url(#grid-large)"/>
  
  <!-- Main compass star -->
  <path d="M256 64L288 192L416 224L288 256L256 384L224 256L96 224L224 192L256 64Z" fill="#ffffff"/>
  
  <!-- Inner circle -->
  <circle cx="256" cy="256" r="32" fill="#2563eb"/>
  
  <!-- Measurement marks -->
  <line x1="256" y1="128" x2="256" y2="160" stroke="#ffffff" stroke-width="8"/>
  <line x1="256" y1="352" x2="256" y2="384" stroke="#ffffff" stroke-width="8"/>
  <line x1="128" y1="256" x2="160" y2="256" stroke="#ffffff" stroke-width="8"/>
  <line x1="352" y1="256" x2="384" y2="256" stroke="#ffffff" stroke-width="8"/>
  
  <!-- Corner brackets -->
  <path d="M64 64L64 128L128 64" stroke="#ffffff" stroke-width="6" fill="none"/>
  <path d="M448 64L448 128L384 64" stroke="#ffffff" stroke-width="6" fill="none"/>
  <path d="M64 448L64 384L128 448" stroke="#ffffff" stroke-width="6" fill="none"/>
  <path d="M448 448L448 384L384 448" stroke="#ffffff" stroke-width="6" fill="none"/>
  
  <!-- Blueprint text -->
  <text x="256" y="460" text-anchor="middle" fill="#ffffff" font-family="Arial, sans-serif" font-size="24" font-weight="bold">BLUEPRINT</text>
</svg>
